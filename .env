# ─────────────────────────────────────────────────────────────
# nQ-Swap Alpha Bot — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# [REQUIRED] Your Discord bot token — from https://discord.com/developers/applications
# ⚠️  If you leaked your old token, regenerate it immediately in the Developer Portal
DISCORD_TOKEN=MTQ3MDczMzA1MzM0NDIxOTEzNg.GzCj9d.rft0uDo-LQa9DHK7aLg3mKrtSimEke8dNhN44U

# [REQUIRED] Discord channel ID where the bot posts alpha drops
CHANNEL_ID=1393225994273423451

# [REQUIRED] Your Discord server (guild) ID
GUILD_ID=1393214506750050414

# [OPTIONAL] Role names for permission gating (exact names from your server)
ADMIN_ROLE_NAME=Admin
ALPHA_ROLE_NAME=Alpha

# [OPTIONAL] How often to auto-post market pulse (in hours, default: 6)
POST_INTERVAL_HOURS=6

# [OPTIONAL] Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
